# Application
APP_NAME=OpsPilot-AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+psycopg2://opspilot:opspilot@localhost:5432/opspilot
# For quick local dev you can use SQLite:
# DATABASE_URL=sqlite:///./opspilot.db

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# One of: anthropic | openai | gemini
LLM_PROVIDER=anthropic
# Model name must match the provider:
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o-mini
#   gemini    -> gemini-2.5-flash-lite  (active free tier; gemini-2.0-flash now has 0 free quota)
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_MIN_CONFIDENCE=0.6

# Vector DB (Chroma - local persistent)
VECTOR_DB_PATH=./.chroma

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000
